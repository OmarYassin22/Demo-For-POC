{
  "rewrites": [
    { "source": "/3d-conditions_images/(.*)", "destination": "/3d-conditions_images/$1" },
    { "source": "/Str/(.*)", "destination": "/Str/$1" },
    { "source": "/styles/(.*)", "destination": "/styles/$1" },
    { "source": "/sound/(.*)", "destination": "/sound/$1" },
    { "source": "/Scripts/(.*)", "destination": "/Scripts/$1" },
    { "source": "/header.png", "destination": "/header.png" },
    { "source": "/footer1.png", "destination": "/footer1.png" },
    { "source": "/footer2.png", "destination": "/footer2.png" },
    { "source": "/footer3.png", "destination": "/footer3.png" },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/offices",
      "destination": "/index.html"
    },
    {
      "source": "/login",
      "destination": "/index.html"
    },
    {
      "source": "/offices/:id/requests",
      "destination": "/index.html"
    },
    {
      "source": "/offices/:id/request/:requestid",
      "destination": "/index.html"
    },
    {
      "source": "/conditions/:krookiNumber",
      "destination": "/index.html"
    },
    {
      "source": "/InspectionReport/:krookiNumber",
      "destination": "/index.html"
    },
    {
      "source": "/AutodeskResultViewer",
      "destination": "/index.html"
    },
    {
      "source": "/ViewCompliance",
      "destination": "/index.html"
    },
    {
      "source": "/arc",
      "destination": "/index.html"
    },
    {
      "source": "/str",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}